---
// 获取当前网页的真实路径，以及 Astro 自动识别的当前语言状态
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // 去除尾部斜杠的项目基础路径（本地为 ''，线上为 '/jiacheng'）
let pathname = Astro.url.pathname;

// 如果路径中带有基础路径前缀，将其剥离，防止干扰中英文高亮和切换逻辑
if (base && pathname.startsWith(base)) {
  pathname = pathname.substring(base.length);
}
if (!pathname.startsWith('/')) {
  pathname = '/' + pathname;
}

const currentLang = Astro.currentLocale || 'zh'; // 'zh' 或 'en'

// 👈 新增：定义 Props 接口，允许外部组件传入精准切换路径
interface Props {
  langAlt?: string;
}
const { langAlt } = Astro.props;

// 统一处理链接的辅助函数（自动在打包时补全 /jiacheng 前缀）
const resolveUrl = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};

// 判断当前路径是否与菜单匹配
const isActive = (path: string) => {
  if (path === '/' || path === '/en') {
    return pathname === '/' || pathname === '/en' || pathname === '';
  }
  return pathname.startsWith(path);
};

// 菜单配置（已为您在产品中心下加入了四个子分类）
const menuTranslations = {
  zh: [
    { name: '首页', href: '/' },
    { name: '公司简介', href: '/about' },
    { name: '新闻中心', href: '/news' },
    { 
      name: '产品中心', 
      href: '/products',
      children: [
        { name: '全部产品', href: '/products' },
        { name: '后挂式', href: '/products/rear-mounted' }, // 👈 可根据您的 Astro 路由结构修改 href
        { name: '底插式', href: '/products/bottom-insertion' },
        { name: '快插式', href: '/products/quick-insertion' },
        { name: '侧挂式', href: '/products/side-mounted' }
      ]
    },
    { name: '招贤纳士', href: '/careers' },
    { name: '联系我们', href: '/contact' },
  ],
  en: [
    { name: 'Home', href: '/en' },
    { name: 'About Us', href: '/en/about' },
    { name: 'News', href: '/en/news' },
    { 
      name: 'Products', 
      href: '/en/products',
      children: [
        { name: 'All Products', href: '/en/products' },
        { name: 'Rear-mounted', href: '/en/products/rear-mounted' },
        { name: 'Bottom-insertion', href: '/en/products/bottom-insertion' },
        { name: 'Quick-insertion', href: '/en/products/quick-insertion' },
        { name: 'Side-mounted', href: '/en/products/side-mounted' }
      ]
    },
    { name: 'Careers', href: '/en/careers' },
    { name: 'Contact Us', href: '/en/contact' },
  ]
};

const menuItems = menuTranslations[currentLang];

// 计算切换语言时的目标网址
const getTargetLangHref = () => {
  // 👈 新增：如果外部传入了精准跳转路径（多语言详情页），优先使用它
  if (langAlt) return langAlt; 

  if (currentLang === 'zh') {
    // 中文切英文：在路径前加上 /en
    return pathname === '/' ? '/en' : `/en${pathname}`;
  } else {
    // 英文切中文：删掉路径最前方的 /en
    return pathname.startsWith('/en/') ? pathname.replace('/en', '') : '/';
  }
};
---

<!-- header 加上 relative，确保下方移动端绝对定位下拉菜单对齐精准 -->
<header class="bg-white/95 backdrop-blur-md border-b border-slate-200 py-4 px-6 md:px-8 sticky top-0 z-50 shadow-[0_2px_15px_rgba(0,0,0,0.01)] relative">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    
    <!-- 左侧：公司品牌 LOGO -->
    <a href={resolveUrl(currentLang === 'zh' ? '/' : '/en')} class="flex items-center shrink-0 group select-none">
      <img 
        src={resolveUrl('/images/logo.png')} 
        alt="嘉程新能源 Logo" 
        class="h-9 md:h-11 w-auto object-contain transition-transform duration-200 group-hover:scale-105"
      />
      <div class="flex flex-col justify-center border-l border-slate-200 pl-3">
        <span class="text-base md:text-lg font-black tracking-widest text-slate-800 group-hover:text-green-600 transition-colors leading-none">
          嘉程新能源
        </span>
        <span class="text-[9px] md:text-[10px] font-bold text-slate-400 tracking-wider font-mono uppercase mt-1 leading-none">
          JC NEW ENERGY
        </span>
      </div>
    </a>

    <!-- 中间：导航菜单栏（已支持悬浮下拉） -->
    <nav class="hidden lg:flex items-center space-x-6 xl:space-x-8 text-sm font-semibold">
      {menuItems.map(item => {
        // 如果该菜单项有子分类
        if (item.children) {
          return (
            <div class="relative group py-1">
              <a 
                href={resolveUrl(item.href)} 
                class={`transition-all flex items-center gap-1 border-b-2 ${
                  isActive(item.href) 
                    ? 'text-green-600 border-green-600 font-bold' 
                    : 'text-slate-500 border-transparent hover:text-green-600 hover:border-green-600/30'
                }`}
              >
                {item.name}
                <!-- 悬浮时自动旋转的小箭头 -->
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              
              <!-- 下拉菜单容器 -->
              <div class="absolute left-0 top-full pt-2 w-48 hidden group-hover:block z-50">
                <div class="bg-white border border-slate-100 rounded-lg shadow-xl py-2 flex flex-col">
                  {item.children.map(child => (
                    <a 
                      href={resolveUrl(child.href)} 
                      class={`px-4 py-2 text-xs transition-colors font-medium hover:bg-slate-50 ${
                        isActive(child.href) ? 'text-green-600 font-bold' : 'text-slate-600 hover:text-green-600'
                      }`}
                    >
                      {child.name}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          );
        }

        // 普通菜单项
        return (
          <a 
            href={resolveUrl(item.href)} 
            class={`transition-all relative py-1 border-b-2 ${
              isActive(item.href) 
                ? 'text-green-600 border-green-600 font-bold' 
                : 'text-slate-500 border-transparent hover:text-green-600 hover:border-green-600/30'
            }`}
          >
            {item.name}
          </a>
        );
      })}
    </nav>

    <!-- 右侧：语言切换 + B2B 快速获取报价按钮 -->
    <div class="flex items-center gap-4">
      
      <!-- 🌐 中 / EN 一键切换 -->
      <a 
        href={langAlt ? langAlt : resolveUrl(getTargetLangHref())} 
        class="text-xs font-bold px-2.5 py-1.5 rounded-md border border-slate-200 text-slate-500 hover:text-green-600 hover:border-green-600/30 transition-all flex items-center gap-1 cursor-pointer select-none font-mono"
        title={currentLang === 'zh' ? 'Switch to English' : '切换至中文版'}
      >
        🌐 {currentLang === 'zh' ? 'EN' : '中'}
      </a>

      <!-- 获取报价按钮 -->
      <a 
        href={resolveUrl(currentLang === 'zh' ? '/contact' : '/en/contact')} 
        class="hidden sm:inline-block px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-bold text-xs rounded-lg transition-all shadow-md shadow-green-600/10"
      >
        {currentLang === 'zh' ? '获取报价 (Get Quote)' : 'Get Quote'}
      </a>
      
      <button 
        id="mobile-menu-btn" 
        class="lg:hidden text-slate-500 hover:text-slate-800 text-2xl cursor-pointer w-8 h-8 flex items-center justify-center font-mono select-none"
      >
        ☰
      </button>
    </div>

  </div>

  <!-- 📱 移动端下拉菜单（已兼容展示子分类） -->
  <div 
    id="mobile-menu" 
    class="hidden lg:hidden absolute top-full left-0 right-0 bg-white border-b border-slate-200 shadow-xl px-6 py-6 space-y-4 flex flex-col z-50 transition-all"
  >
    {menuItems.map(item => {
      // 如果有子分类
      if (item.children) {
        return (
          <div class="flex flex-col border-b border-slate-100 pb-2.5 last:border-0">
            <span class="py-2.5 text-sm font-extrabold text-slate-800">
              {item.name}
            </span>
            <!-- 缩进排版展示分类列表 -->
            <div class="pl-3 flex flex-col space-y-2 mt-1 border-l-2 border-slate-100">
              {item.children.map(child => (
                <a 
                  href={resolveUrl(child.href)} 
                  class={`py-1 text-xs font-semibold transition-colors ${
                    isActive(child.href) ? 'text-green-600 font-bold' : 'text-slate-500 hover:text-green-600'
                  }`}
                >
                  {child.name}
                </a>
              ))}
            </div>
          </div>
        );
      }

      // 普通移动端菜单项
      return (
        <a 
          href={resolveUrl(item.href)} 
          class={`py-2.5 text-sm font-bold border-b border-slate-100 last:border-0 transition-colors ${
            isActive(item.href) ? 'text-green-600 font-extrabold' : 'text-slate-600 hover:text-green-600'
          }`}
        >
          {item.name}
        </a>
      );
    })}

    <!-- 移动端一键语言切换 -->
    <a 
      href={langAlt ? langAlt : resolveUrl(getTargetLangHref())}
      class="py-2.5 text-sm font-bold border-b border-slate-100 flex items-center gap-1 text-slate-600"
    >
      🌐 {currentLang === 'zh' ? '切换至 English' : 'Switch to Chinese'}
    </a>
    
    <a 
      href={resolveUrl(currentLang === 'zh' ? '/contact' : '/en/contact')} 
      class="w-full py-3 bg-green-600 hover:bg-green-700 text-white text-center font-bold text-xs rounded-lg shadow-md mt-4 block"
    >
      {currentLang === 'zh' ? '获取报价 (Get Quote)' : 'Get Quote'}
    </a>
  </div>
</header>

<!-- 手机端切换脚本 -->
<script is:inline>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    if (mobileMenu) {
      const isHidden = mobileMenu.classList.contains('hidden');
      
      if (isHidden) {
        mobileMenu.classList.remove('hidden');
        menuBtn.textContent = '✕';
      } else {
        mobileMenu.classList.add('hidden');
        menuBtn.textContent = '☰';
      }
    }
  });

  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      if (menuBtn) menuBtn.textContent = '☰';
    });
  });
</script>
