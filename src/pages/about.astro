      <button id="close-lightbox" class="absolute -top-14 right-0 md:top-6 md:right-6 text-slate-400 hover:text-white bg-slate-950/60 hover:bg-slate-800 p-2.5 rounded-full border border-slate-800 transition-colors focus:outline-none" aria-label="关闭预览">
