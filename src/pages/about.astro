  <!-- 8. 灯箱大图弹窗组件 (Lightbox Modal) -->
  <div id="lightbox-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/85 backdrop-blur-md p-4">
    <div class="relative max-w-4xl w-full bg-slate-900/90 border border-slate-800 rounded-3xl p-4 md:p-6 shadow-[0_20px_50px_rgba(16,185,129,0.15)] animate-fade-in">
