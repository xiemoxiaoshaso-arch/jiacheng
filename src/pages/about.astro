<!-- 滚动渐入控制脚本 -->
<script is:inline>
  const revealObserver = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal-section').forEach(section => {
    revealObserver.observe(section);
  });

  // --- 【修改 1】：滑动轨切换逻辑（将 🏭 智造车间 作为默认第一页，即平移 0%） ---
  const tabStats = document.getElementById('tab-stats');
  const tabWorkshops = document.getElementById('tab-workshops');
  const strengthTrack = document.getElementById('strength-track');

  if (tabStats && tabWorkshops && strengthTrack) {
    // 🏭 智造车间 作为第一页，点击回到 0%
    tabWorkshops.addEventListener('click', () => {
      strengthTrack.style.transform = 'translateX(0%)';
      tabWorkshops.classList.add('bg-white', 'text-slate-900', 'shadow-sm');
      tabWorkshops.classList.remove('text-slate-500');
      tabStats.classList.remove('bg-white', 'text-slate-900', 'shadow-sm');
      tabStats.classList.add('text-slate-500');
    });

    // 📊 数据看板 作为第二页，点击平移到 -50%
    tabStats.addEventListener('click', () => {
      strengthTrack.style.transform = 'translateX(-50%)';
      tabStats.classList.add('bg-white', 'text-slate-900', 'shadow-sm');
      tabStats.classList.remove('text-slate-500');
      tabWorkshops.classList.remove('bg-white', 'text-slate-900', 'shadow-sm');
      tabWorkshops.classList.add('text-slate-500');
    });
  }

  // --- 【修改 2】：车间实景大图弹窗 (Lightbox) 控制逻辑 ---
  const lightboxModal = document.getElementById('lightbox-modal');
  const lightboxImg = document.getElementById('lightbox-img');
  const closeLightboxBtn = document.getElementById('close-lightbox');
  const workshopBtns = document.querySelectorAll('.workshop-btn');

  workshopBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const fullImgUrl = btn.getAttribute('data-img-url');
      if (fullImgUrl && lightboxModal && lightboxImg) {
        lightboxImg.src = fullImgUrl;
        lightboxModal.classList.remove('hidden');
        lightboxModal.classList.add('flex');
      }
    });
  });

  function closeLightbox() {
    if (lightboxModal) {
      lightboxModal.classList.add('hidden');
      lightboxModal.classList.remove('flex');
    }
  }

  if (closeLightboxBtn) {
    closeLightboxBtn.addEventListener('click', closeLightbox);
  }

  if (lightboxModal) {
    lightboxModal.addEventListener('click', (e) => {
      if (e.target === lightboxModal) {
        closeLightbox();
      }
    });
  }

  // 监听键盘 ESC 键关闭
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeLightbox();
    }
  });
</script>

</html>