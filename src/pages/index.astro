<!-- 轮播过渡动效控制 -->
<style>
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .carousel-slide.active {
    display: grid !important;
    animation: slideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<!-- 轮播控制脚本与第一屏电芯数据监控模拟 -->
<script is:inline>
  // --- 1. 轮播图控制逻辑 ---
  const slides = document.querySelectorAll('.carousel-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.getElementById('prev-slide');
  const nextBtn = document.getElementById('next-slide');
  
  let currentSlide = 0;
  let autoPlayTimer;
  const cycleInterval = 6000; // 每 6 秒切换一次

  function updateCarousel(index) {
    if (index >= slides.length) currentSlide = 0;
    else if (index < 0) currentSlide = slides.length - 1;
    else currentSlide = index;

    slides.forEach((slide) => {
      slide.classList.add('hidden');
      slide.classList.remove('active');
    });

    dots.forEach((dot) => {
      dot.classList.remove('bg-emerald-500', 'w-6');
      dot.classList.add('bg-slate-600', 'w-3');
    });

    slides[currentSlide].classList.remove('hidden');
    slides[currentSlide].classList.add('active');

    dots[currentSlide].classList.add('bg-emerald-500', 'w-6');
    dots[currentSlide].classList.remove('bg-slate-600', 'w-3');
  }

  function startAutoPlay() {
    stopAutoPlay();
    autoPlayTimer = setInterval(() => {
      updateCarousel(currentSlide + 1);
    }, cycleInterval);
  }

  function stopAutoPlay() {
    if (autoPlayTimer) clearInterval(autoPlayTimer);
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      updateCarousel(currentSlide - 1);
      startAutoPlay();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      updateCarousel(currentSlide + 1);
      startAutoPlay();
    });
  }

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      updateCarousel(index);
      startAutoPlay();
    });
  });

  const heroSection = document.querySelector('section');
  if (heroSection) {
    heroSection.addEventListener('mouseenter', stopAutoPlay);
    heroSection.addEventListener('mouseleave', startAutoPlay);
  }

  updateCarousel(0);
  startAutoPlay();

  // --- 2. 模拟数据监控波动面板逻辑（仅服务于第一屏保留的仪表盘） ---
  const vEl = document.getElementById('live-voltage');
  const tEl = document.getElementById('live-temp');
  
  if (vEl && tEl) {
    setInterval(() => {
      // 电压在 3.280V ~ 3.288V 之间高频波动
      const fakeVoltage = (3.280 + Math.random() * 0.008).toFixed(3);
      vEl.textContent = `${fakeVoltage} V`;
      
      // 温度在 25.1℃ ~ 25.5℃ 之间平滑微动
      const fakeTemp = (25.1 + Math.random() * 0.4).toFixed(1);
      tEl.textContent = `${fakeTemp} ℃`;
    }, 2000);
  }
</script>

