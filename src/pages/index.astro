---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets'; // 👈 导入 Astro 核心图片优化组件
import '../styles/global.css'; 
import Header from '../components/Header.astro'; 

// 统一处理链接和公开静态资源路径的辅助函数（兼容子目录部署环境）
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};

// 1. 读取并精准筛选：基于 Frontmatter 的 lang 字段提取中文产品
const allProducts = await getCollection('products');
const zhProducts = allProducts.filter(product => product.data.lang === 'zh');

// 2. 挑选前两款作为首页的“明星产品”展示
const featuredProducts = zhProducts.slice(0, 2);

// 3. 读取并精准筛选中文 Banner，按 order 升序排序
const allBanners = await getCollection('banners');
const zhBanners = allBanners
  .filter(banner => banner.data.lang === 'zh')
  .sort((a, b) => a.data.order - b.data.order);
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>嘉程新能源 | 全球领先的锂电池及储能系统解决方案提供商</title>
</head>
<body class="bg-slate-50 text-slate-800 antialiased font-sans">

  <!-- 1. 顶部导航栏 -->
  <Header /> 

  <!-- 2. 首屏 Hero 轮播区域 -->
  <section class="relative bg-slate-950 text-white overflow-hidden h-[calc(100vh-80px)] min-h-[620px] flex items-center">
    
    <!-- 轮播幻灯片主容器 -->
    <div class="absolute inset-0 w-full h-full">
      {zhBanners.map((banner, index) => {
        const isFirst = index === 0;
        const { 
          badge, 
          badgeColor, 
          title, 
          subtitle, 
          description, 
          bgImage, 
          ctaText1, 
          ctaLink1, 
          ctaText2, 
          ctaLink2, 
          gallery 
        } = banner.data;
        
        // 动态计算配色主题
        let badgeClass = "bg-emerald-500/10 text-emerald-400 border-emerald-500/20";
        let glowClass = "bg-[radial-gradient(circle_at_25%_35%,rgba(16,185,129,0.15),transparent_60%)]";
        let rightGlowClass = "from-emerald-500 to-teal-500";
        
        if (badgeColor === 'blue') {
          badgeClass = "bg-blue-500/10 text-blue-400 border-blue-500/20";
          glowClass = "bg-[radial-gradient(circle_at_25%_35%,rgba(59,130,246,0.15),transparent_60%)]";
          rightGlowClass = "from-blue-500 to-emerald-500";
        } else if (badgeColor === 'cyan') {
          badgeClass = "bg-cyan-500/10 text-cyan-400 border-cyan-500/20";
          glowClass = "bg-[radial-gradient(circle_at_25%_35%,rgba(34,211,238,0.15),transparent_60%)]";
          rightGlowClass = "from-cyan-500 to-blue-500";
        }

        return (
          <div class={`carousel-slide absolute inset-0 w-full h-full flex items-center ${isFirst ? 'active z-10' : 'hidden z-0'}`}>
            <!-- 背景大图层 (👈 核心修改 1：改用 Astro 原生 Image 组件，渲染被 image() 解析优化后的对象) -->
            <!-- 背景大图层 (👈 彻底去除任何变暗遮罩、滤镜和不透明度，100% 完美还原您原图的真实亮度和鲜艳色彩) -->
            <div class="absolute inset-0 z-0 select-none pointer-events-none w-full h-full">
              <Image 
                src={bgImage} 
                alt={`${title}背景`} 
                class="w-full h-full object-cover" 
                loading={isFirst ? "eager" : "lazy"}
                inferSize={true}
              />
              <!-- 
                1. 彻底删除了先前添加的 `<div class="absolute inset-0 bg-slate-950/20"></div>` 变暗层。
                2. 去掉了 `opacity-90`，图片不再半透明，底部的黑色完全不会再透出来。
                3. 去掉了所有的 `brightness` 和 `contrast` CSS 滤镜，也去掉了多彩的光晕叠加。
                现在，您的原图将以最真实、最明亮、原汁原味的日光状态完美展现！
              -->
            </div>
            
            <!-- 内容排版容器 -->
            <div class="relative z-10 w-full max-w-7xl mx-auto px-6 h-full flex flex-col lg:flex-row justify-between py-24 md:py-28 gap-10">
              
              <!-- 左侧：文字板块 -->
              <div class="w-full lg:max-w-[480px] lg:self-end space-y-6">
                <span class={`inline-block px-3 py-1 text-xs font-semibold rounded-full border ${badgeClass} backdrop-blur-sm`}>
                  {badge}
                </span>
                <h2 class="text-2xl md:text-3xl lg:text-4xl font-extrabold tracking-tight leading-tight text-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.85)]">
                  {title}，<br />
                  <span class="text-slate-100">{subtitle}</span>
                </h2>
                <p class="text-slate-100 text-xs md:text-sm leading-relaxed drop-shadow-[0_2px_4px_rgba(0,0,0,0.85)]">
                  {description}
                </p>
                <div class="flex flex-col sm:flex-row gap-3 pt-2">
                  <a href={resolveUrl(ctaLink1)} class="px-6 py-3.5 bg-emerald-500 hover:bg-emerald-600 text-center text-xs font-bold rounded-lg shadow-lg transition-colors">
                    {ctaText1}
                  </a>
                  <a href={resolveUrl(ctaLink2)} class="px-6 py-3.5 border border-slate-600 hover:border-slate-400 text-center text-xs font-bold rounded-lg transition-colors text-slate-200 bg-slate-950/30 backdrop-blur-sm">
                    {ctaText2}
                  </a>
                </div>
              </div>
              
              <!-- 右侧：缩略图图集组 (去除了内衬灰色，绿框紧贴图片) -->
              <div class="w-full lg:max-w-[420px] lg:self-end flex justify-center lg:justify-end gap-3 sm:gap-4 ml-auto">
                {gallery.slice(0, 3).map((imgObj, imgIndex) => (
                  <button 
                    class="thumbnail-btn w-16 h-16 sm:w-20 sm:h-20 lg:w-24 lg:h-24 rounded-2xl overflow-hidden border-2 border-emerald-400 hover:border-emerald-300 hover:scale-105 active:scale-95 transition-all duration-300 bg-transparent group relative shadow-2xl focus:outline-none p-0" 
                    data-img-url={imgObj.src} 
                    aria-label={`查看高清大图 ${imgIndex + 1}`}
                  >
                    <!-- 
                      - rounded-[14px] 能让图片角弧度与 2xl (16px) 的外框绿边实现完美的无缝贴合 
                    -->
                    <Image 
                      src={imgObj} 
                      alt={`缩略图 ${imgIndex + 1}`} 
                      class="w-full h-full object-cover rounded-[14px]" 
                      inferSize={true} 
                    />
                    <!-- 磨砂悬浮亮色遮罩，同样采用 rounded-[14px] 贴合 -->
                    <div class="absolute inset-0 bg-slate-950/20 group-hover:bg-transparent transition-colors rounded-[14px]"></div>
                  </button>
                ))}
              </div>
              
            </div>
          </div>
        );
      })}
    </div>

    <!-- 左右控制器 -->
    <button id="prev-slide" class="absolute left-4 top-1/2 -translate-y-1/2 z-30 flex items-center justify-center w-11 h-11 rounded-full bg-slate-950/40 hover:bg-emerald-500 border border-slate-850 text-white transition-all duration-300 focus:outline-none backdrop-blur-sm" aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button id="next-slide" class="absolute right-4 top-1/2 -translate-y-1/2 z-30 flex items-center justify-center w-11 h-11 rounded-full bg-slate-950/40 hover:bg-emerald-500 border border-slate-850 text-white transition-all duration-300 focus:outline-none backdrop-blur-sm" aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    </button>

    <!-- 进度 Dots 指标 -->
    <div class="absolute bottom-20 left-1/2 -translate-x-1/2 z-30 flex space-x-3">
      {zhBanners.map((_, index) => (
        <button 
          class={`carousel-dot h-3 rounded-full transition-all duration-300 ${index === 0 ? 'bg-emerald-500 w-6' : 'bg-slate-600 hover:bg-slate-500 w-3'}`} 
          aria-label={`Go to slide ${index + 1}`}
