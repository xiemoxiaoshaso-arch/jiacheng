---
import { getCollection, render } from 'astro:content'; 
import { Image } from 'astro:assets'; 
import '../../styles/global.css';
import Header from '../../components/Header.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};

export async function getStaticPaths() {
  const newsList = await getCollection('news');
  
  // 👈 修改：过滤出 lang === 'zh' 的新闻，避免英文文章错误生成中文版页面
  const zhNewsList = newsList.filter(news => news.data.lang === 'zh');
  
  return zhNewsList.map(news => ({
    params: { id: news.id },
    props: { news }
  }));
}

const { news } = Astro.props;
// 👈 修改：提取 description（如有）用于 SEO
const { title, category, categoryName, date, views, image, description } = news.data;
const { Content } = await render(news); 
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - 嘉程新能源</title>
  {description && <meta name="description" content={description} />}
</head>
<body class="bg-slate-50 text-slate-800 font-sans leading-normal tracking-normal antialiased">

  <!-- 1. 导航栏 -->
  <Header />

  <!-- 2. 正文 -->
  <main class="max-w-4xl mx-auto px-4 py-12">
    
    <a href={resolveUrl('/news')} class="inline-flex items-center gap-1.5 text-xs font-semibold text-slate-500 hover:text-green-600 transition-colors mb-6 group">
      ⬅ 返回新闻中心
    </a>

    <article class="bg-white rounded-3xl border border-slate-200 p-8 md:p-12 shadow-sm space-y-8">
      
      <div class="space-y-4 border-b border-slate-100 pb-6">
        <span class={`inline-block px-2.5 py-1 text-[10px] font-extrabold rounded-full border ${
          category === 'corporate' 
            ? 'bg-green-50 text-green-700 border-green-200/60' 
            : 'bg-cyan-50 text-cyan-700 border-cyan-200/60'
        }`}>
          {categoryName}
        </span>
        <h1 class="text-2xl md:text-3xl font-black text-slate-900 leading-snug">
          {title}
        </h1>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-slate-400 font-mono">
          <span>📅 发布时间：{date}</span>
          <span>✍️ 作者：嘉程新能源编辑部</span>
          <span>👁️ 阅读：{views}</span>
        </div>
      </div>

      <div class="w-full aspect-video bg-slate-50 rounded-2xl overflow-hidden border border-slate-100">
        <!-- 👈 修改：为首屏大图设置优化尺寸、响应式 sizes 以及 eager 加载 -->
        <Image 
          src={image} 
          alt={title} 
          width={1200}
          height={675}
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, 800px"
          loading="eager"
          class="w-full h-full object-cover" 
        />
      </div>

      <!-- 👈 修改：调整 prose 渲染类，配合 prose-slate 以保证中文字体排版颜色符合预期 -->
      <div class="prose prose-slate max-w-none prose-p:text-slate-600 prose-p:text-sm md:prose-p:text-base prose-p:leading-relaxed prose-headings:font-bold prose-headings:text-slate-900">
        <Content />
      </div>

      <div class="mt-12 p-6 bg-slate-50 rounded-2xl border border-slate-150/60 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div class="space-y-0.5">
          <h4 class="font-extrabold text-slate-900 text-sm">关注嘉程新能源，获取最新电芯解决方案</h4>
          <p class="text-xs text-slate-400">我们将持续为您输出全球最前沿的锂电安全与工商业储能干货咨询。</p>
        </div>
        <a href={resolveUrl('/products')} class="px-5 py-2.5 bg-slate-900 hover:bg-slate-800 text-white font-bold text-xs rounded-xl transition-all shadow-sm shrink-0 whitespace-nowrap">
          浏览产品库 ➔
        </a>
      </div>

    </article>

    <div class="text-center mt-12">
      <a href={resolveUrl('/news')} class="inline-flex px-6 py-3 bg-white border border-slate-200 hover:border-green-600 hover:text-green-600 text-slate-600 text-xs font-bold rounded-xl transition-colors shadow-sm">
        返回新闻中心
      </a>
    </div>

  </main>

  <footer class="bg-slate-900 text-slate-400 py-12 px-6 border-t border-slate-950 mt-20">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <div>© {new Date().getFullYear()} 嘉程新能源股份公司. All rights reserved.</div>
      <div class="flex gap-6">
        <a href={resolveUrl('/')} class="hover:text-green-600">首页</a>
        <a href={resolveUrl('/products')} class="hover:text-green-600">产品中心</a>
        <a href={resolveUrl('/contact')} class="hover:text-green-600">在线留言</a>
      </div>
    </div>
  </footer>

</body>
</html>