---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets'; // 👈 导入 Astro 5 原生图片优化组件
import '../../styles/global.css';
import Header from '../../components/Header.astro';

// 统一处理路径和链接补全的辅助函数
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  if (!path) return '';
  if (path.startsWith('http') || path.startsWith('data:')) return path;
  if (path === '/') return base || '/';
  return `${base}${path}`;
};

export async function getStaticPaths() {
  const products = await getCollection('products');
  
  // 👈 过滤：基于 Frontmatter 的 lang 字段，确保只为中文版（lang === 'zh'）产品生成路由
  const zhProducts = products.filter(product => product.data.lang === 'zh');

  return zhProducts.map(product => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { title, category, chemistry, image, datasheet, specs, images, description } = product.data;
const { Content } = await render(product);

// 👈 重构：直接提取原始 Image 对象列表（无需转换成 string），便于 <Image /> 处理
const galleryImages = images && images.length > 0 ? images : [image];

// 处理 PDF 规格书的路径
const resolvedDatasheet = resolveUrl(datasheet);
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - 嘉程新能源</title>
  {description && <meta name="description" content={description} />}
</head>
<body class="bg-slate-50 text-slate-800 antialiased font-sans">

  <!-- 顶部导航栏 -->
  <Header langAlt={resolveUrl(`/en/products/${products.id}-en`)} />

  <main class="max-w-7xl mx-auto px-4 py-12 space-y-8">
    <!-- 面包屑导航 -->
    <nav class="text-xs font-semibold text-slate-400 tracking-wider">
      <a href={resolveUrl('/')} class="hover:text-emerald-600 transition-colors">首页</a> 
      <span class="mx-1">&gt;</span> 
      <a href={resolveUrl('/products')} class="hover:text-emerald-600 transition-colors">产品中心</a> 
      <span class="mx-1">&gt;</span> 
      <span class="text-slate-500">{category}</span> 
      <span class="mx-1">&gt;</span> 
      <span class="text-slate-600 font-medium">{title}</span>
    </nav>

    <!-- 核心板块：经典的左右双卡片分栏布局 -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- ================= 左侧卡片 ================= -->
      <div class="lg:col-span-5 bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col items-center w-full">
        <!-- 👈 重构主图显示框：将所有优化图叠加，通过不透明度动画切换 -->
        <div class="w-full aspect-square bg-slate-50 rounded-xl overflow-hidden flex items-center justify-center p-8 border border-slate-100 relative">
          {galleryImages.map((imgObj, idx) => (
            <Image
              src={imgObj}
              alt={`${title} - 视角 ${idx + 1}`}
              width={600}
              height={600}
              widths={[300, 600, 900]}
              sizes="(max-width: 768px) 100vw, 500px"
              loading={idx === 0 ? "eager" : "lazy"} // 首张首屏预载，非首张延迟加载
              class={`absolute max-h-[85%] max-w-[85%] object-contain transition-all duration-300 product-gallery-img ${idx === 0 ? 'opacity-100 scale-100 z-10' : 'opacity-0 scale-95 pointer-events-none z-0'}`}
              data-index={idx}
            />
          ))}
        </div>

        <!-- 👈 重构缩略图滚动条：缩略图本身也使用高阶 <Image /> 进行优化 -->
        {galleryImages.length > 1 && (
          <div class="flex gap-2.5 mt-4 w-full overflow-x-auto pb-1 scrollbar-none justify-start">
            {galleryImages.map((imgObj, index) => (
              <button 
                class={`thumb-btn w-16 h-16 rounded-xl border overflow-hidden flex items-center justify-center p-1 bg-slate-50 shrink-0 cursor-pointer transition-all ${index === 0 ? 'border-emerald-600 ring-4 ring-emerald-500/10' : 'border-slate-200 hover:border-slate-300'}`}
                data-target-index={index}
              >
                <Image 
                  src={imgObj} 
                  alt="产品角度缩略图" 
                  width={100}
                  height={100}
                  class="max-h-full object-contain pointer-events-none" 
                />
              </button>
            ))}
          </div>
        )}

        <!-- 下载规格书大按钮 -->
        <button id="download-trigger-btn" class="mt-6 w-full py-3.5 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg shadow-md transition-all cursor-pointer text-sm">
          📥 下载产品技术规格书 (Datasheet PDF)
        </button>

        <!-- 符合全球准入认证 -->
        <div class="w-full mt-6 border-t border-slate-100 pt-6">
          <h4 class="text-xs font-bold text-slate-400 tracking-wider uppercase mb-4 flex items-center gap-1.5">
            <span class="w-1 h-2.5 bg-emerald-600 rounded-sm"></span>
            符合全球准入认证
          </h4>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-white p-2.5 rounded-lg border border-slate-200 hover:border-emerald-500/20 transition-all flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-left">
                <div class="text-[10px] font-extrabold text-slate-800 leading-tight">UL 1973</div>
                <div class="text-[8px] text-slate-400">北美储能</div>
              </div>
            </div>

            <div class="bg-white p-2.5 rounded-lg border border-slate-200 hover:border-emerald-500/20 transition-all flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-left">
                <div class="text-[10px] font-extrabold text-slate-800 leading-tight">IEC 62619</div>
                <div class="text-[8px] text-slate-400">欧洲工业</div>
              </div>
            </div>

            <div class="bg-white p-2.5 rounded-lg border border-slate-200 hover:border-emerald-500/20 transition-all flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-left">
                <div class="text-[10px] font-extrabold text-slate-800 leading-tight">UN 38.3</div>
                <div class="text-[8px] text-slate-400">航空运输</div>
              </div>
            </div>

            <div class="bg-white p-2.5 rounded-lg border border-slate-200 hover:border-emerald-500/20 transition-all flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-left">
                <div class="text-[10px] font-extrabold text-slate-800 leading-tight">CE / CB</div>
                <div class="text-[8px] text-slate-400">欧盟安全</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ================= 右侧卡片 ================= -->
      <div class="lg:col-span-7 bg-white p-8 rounded-2xl shadow-sm border border-slate-200 flex flex-col justify-between w-full h-full space-y-6">
        <div>
          <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold rounded-full border border-emerald-100">{chemistry} | {category}</span>
          <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 mt-3">{title}</h1>
          <p class="text-slate-500 mt-2 text-xs md:text-sm leading-relaxed">
            专为高标准储能及动力应用定制研发。采用全生命周期安全监控，具备极佳的热稳定性与优异的倍率放电性能，支持多维度非标定制。
          </p>
        </div>

        <!-- 技术参数表 -->
        <div>
          <h2 class="text-sm font-bold text-slate-900 mb-3 flex items-center gap-1.5">
            📊 核心技术规格参数 (Specifications)
          </h2>
          <div class="overflow-hidden border border-slate-200 rounded-xl shadow-sm">
            <table class="min-w-full divide-y divide-slate-150 bg-white">
              <tbody class="divide-y divide-slate-100">
                {specs.map((spec: any, index: number) => (
                  <tr class={index % 2 === 0 ? 'bg-slate-50/50' : 'bg-white'}>
                    <td class="px-5 py-3 text-xs font-semibold text-slate-500 w-1/2 border-r border-slate-100">{spec.name}</td>
                    <td class="px-5 py-3 text-xs font-bold text-slate-900">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- 快速询盘 -->
        <div class="p-5 bg-slate-50 rounded-xl border border-slate-150 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
          <div class="space-y-0.5">
            <h3 class="font-bold text-slate-900 text-xs">需要定制或获取大货报价？</h3>
            <p class="text-[11px] text-slate-400">我们的应用工程师可为您提供完整的电池Pack或系统方案。</p>
          </div>
          <a href={resolveUrl('/contact')} class="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold text-xs rounded-lg transition-colors shadow-sm shrink-0">
            联系应用工程师 ➔
          </a>
        </div>
      </div>

    </div>

    <!-- 下方：通栏详细介绍 -->
    <!-- 👈 修改：应用中文 Typography 类 (prose-slate、prose-p:leading-relaxed) -->
    <section class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 prose prose-slate max-w-none">
      <h2 class="text-lg font-bold text-slate-900 border-b border-slate-100 pb-3">产品应用与技术细节</h2>
      <div class="mt-4 text-sm text-slate-600 leading-relaxed">
        <Content />
      </div>
    </section>

  </main>

  <!-- PDF 规格书留资保护弹窗 -->
  <div id="pdf-lead-modal" class="fixed inset-0 bg-slate-950/60 backdrop-blur-sm flex items-center justify-center z-[100] opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl border border-slate-200 relative transform translate-y-4 transition-transform duration-300" id="modal-box">
      <button id="close-modal-btn" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 text-xl cursor-pointer">✕</button>
      
      <div class="text-center mb-6">
        <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center text-xl mx-auto mb-3">📄</div>
        <h3 class="text-xl font-bold text-slate-900">请填写邮箱以获取规格书</h3>
        <p class="text-xs text-slate-400 mt-1.5">我们将立即通过浏览器下载，并发送一份副本到您的邮箱</p>
      </div>

      <form id="lead-form" class="space-y-4">
        <div>
          <label class="block text-xs font-bold text-slate-500 uppercase mb-1">企业邮箱 (Work Email)*</label>
          <input type="email" id="lead-email" required class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-emerald-500 bg-slate-50" placeholder="example@company.com" />
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-500 uppercase mb-1">国家 / 地区 (Country)*</label>
          <input type="text" id="lead-country" required class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-emerald-500 bg-slate-50" placeholder="例如：德国、美国" />
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-500 uppercase mb-1">应用场景 (Application)*</label>
          <select id="lead-app" required class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-emerald-500 bg-slate-50">
            <option value="">请选择...</option>
            <option value="ESS">储能系统 (ESS)</option>
            <option value="EV">动力电池 (EV / E-Mobility)</option>
            <option value="Industrial">工业与消费电池 (Industrial)</option>
            <option value="Other">其他 (Other)</option>
          </select>
        </div>

        <button type="submit" class="w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-lg text-sm transition-all shadow-md shadow-emerald-600/10 cursor-pointer">
          验证并开始下载 ➔
        </button>
      </form>
    </div>
  </div>

  <!-- 👈 脚本重构：配合纯原生图片优化，利用不透明度和 Z-Index 做原生动态切换 -->
  <script is:inline define:vars={{ datasheet: resolvedDatasheet }}>
    const openBtn = document.getElementById('download-trigger-btn');
    const closeBtn = document.getElementById('close-modal-btn');
    const modal = document.getElementById('pdf-lead-modal');
    const modalBox = document.getElementById('modal-box');
    const form = document.getElementById('lead-form');

    // 👈 修改：缩略图交互切换逻辑
    const galleryImgs = document.querySelectorAll('.product-gallery-img');
    const thumbBtns = document.querySelectorAll('.thumb-btn');

    thumbBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const targetBtn = e.currentTarget;
        const targetIdx = targetBtn.getAttribute('data-target-index');
        
        // 1. 切换缩略图的高亮边框
        thumbBtns.forEach(b => {
          b.classList.remove('border-emerald-600', 'ring-4', 'ring-emerald-500/10');
          b.classList.add('border-slate-200');
        });
        targetBtn.classList.remove('border-slate-200');
        targetBtn.classList.add('border-emerald-600', 'ring-4', 'ring-emerald-500/10');

        // 2. 切换当前显示的主图不透明度和层级（避免破坏原生 Image 生成的 srcset 优化）
        galleryImgs.forEach(img => {
          const imgIdx = img.getAttribute('data-index');
          if (imgIdx === targetIdx) {
            img.classList.remove('opacity-0', 'scale-95', 'pointer-events-none', 'z-0');
            img.classList.add('opacity-100', 'scale-100', 'z-10');
          } else {
            img.classList.remove('opacity-100', 'scale-100', 'z-10');
            img.classList.add('opacity-0', 'scale-95', 'pointer-events-none', 'z-0');
          }
        });
      });
    });

    // 弹窗逻辑
    openBtn?.addEventListener('click', () => {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modalBox.classList.remove('translate-y-4');
    });

    function closeModal() {
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalBox.classList.add('translate-y-4');
    }
    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const email = document.getElementById('lead-email').value;
      const country = document.getElementById('lead-country').value;
      const app = document.getElementById('lead-app').value;

      console.log('🎉 收集到高质量 B2B 询盘：', { email, country, app, time: new Date() });

      const downloadLink = document.createElement('a');
      downloadLink.href = datasheet;
      downloadLink.download = datasheet.split('/').pop() || 'Datasheet.pdf';
      document.body.appendChild(downloadLink);
      downloadLink.click();
      document.body.removeChild(downloadLink);

      closeModal();
      alert('规格书下载已开始！我们的应用工程师稍后也会通过邮件发送一份详细方案给您。');
    });
  </script>

</body>
</html>