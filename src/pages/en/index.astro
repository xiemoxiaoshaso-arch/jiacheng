---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets'; // 👈 导入 Astro 原生图片优化组件
import '../../styles/global.css'; // 👈 引入样式（相对路径已调整）
import Header from '../../components/Header.astro'; // 👈 引入通用双语导航（相对路径已调整）

// 统一处理链接的辅助函数（自动补全自定义域名根路径或本地子路径前缀）
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};

// 1. 获取所有产品数据
const allProducts = await getCollection('products');

// 2. 👈 重构核心过滤逻辑：与中文版统一，通过 Frontmatter 中的 lang === 'en' 属性精准提取英文产品
const englishProducts = allProducts.filter(product => product.data.lang === 'en');
const featuredProducts = englishProducts.slice(0, 2);
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>JC New Energy | Global Leading Provider of Lithium Battery & ESS Solutions</title>
</head>
<body class="bg-slate-50 text-slate-800 antialiased font-sans">

  <!-- 1. 顶部导航栏 -->
  <Header /> 

  <!-- 2. 首屏 Hero 区域 -->
  <section class="relative bg-slate-900 text-white py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(16,185,129,0.15),transparent_50%)]"></div>
    
    <div class="max-w-7xl mx-auto px-6 relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 space-y-6">
        <span class="inline-block px-3 py-1 bg-emerald-500/10 text-emerald-400 text-xs font-semibold rounded-full border border-emerald-500/20">
          Industrial & Utility Battery Solution Expert
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
          Powering a Green Future,<br />
          Defining New Energy with Safety & Quality
        </h1>
        <p class="text-slate-300 text-lg md:text-xl max-w-xl">
          We focus on the R&D and system integration of high-safety, long-life Lithium Iron Phosphate (LFP) cells. With a planned annual capacity of 15 GWh, we deliver one-stop customized power & ESS solutions.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a href={resolveUrl('/en/products')} class="px-8 py-4 bg-emerald-500 hover:bg-emerald-600 text-slate-950 text-center font-bold rounded-lg shadow-lg transition-colors">
            Browse Products ➔
          </a>
          <a href={resolveUrl('/en/contact')} class="px-8 py-4 border border-slate-500 hover:border-white text-center font-bold rounded-lg transition-colors">
            Get Bulk Quote
          </a>
        </div>
      </div>
      
      <!-- 右侧：实时数据监控模拟面板 -->
      <div class="lg:col-span-5 flex justify-center">
        <div class="w-full max-w-md bg-slate-900/90 backdrop-blur-md rounded-2xl border border-slate-800 p-6 shadow-[0_15px_35px_rgba(16,185,129,0.15)] relative">
          <div class="flex justify-between items-center border-b border-slate-800 pb-4 mb-4">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500 animate-ping"></span>
              <span class="text-[11px] font-bold tracking-widest text-emerald-400 uppercase font-mono">SYS MONITOR // LIVE</span>
            </div>
            <span class="text-[10px] text-slate-500 font-mono">ID: LFP_CELL_280AH</span>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="bg-slate-950 p-4 rounded-xl border border-slate-800/80">
              <div class="text-[10px] text-slate-500 uppercase tracking-wider font-semibold">Cell Voltage</div>
              <div class="text-2xl font-extrabold text-emerald-400 font-mono mt-1" id="live-voltage">3.284 V</div>
            </div>
            <div class="bg-slate-950 p-4 rounded-xl border border-slate-800/80">
              <div class="text-[10px] text-slate-500 uppercase tracking-wider font-semibold">Working Temp</div>
              <div class="text-2xl font-extrabold text-cyan-400 font-mono mt-1" id="live-temp">25.3 ℃</div>
            </div>
            <div class="bg-slate-950 p-4 rounded-xl border border-slate-800/80">
              <div class="text-[10px] text-slate-400 uppercase tracking-wider font-semibold">State of Charge</div>
              <div class="text-2xl font-extrabold text-white font-mono mt-1">98.2 %</div>
            </div>
            <div class="bg-slate-950 p-4 rounded-xl border border-slate-800/80">
              <div class="text-[10px] text-slate-400 uppercase tracking-wider font-semibold">State of Health</div>
              <div class="text-2xl font-extrabold text-white font-mono mt-1">100.0 %</div>
            </div>
          </div>

          <div class="mt-4 p-3 bg-slate-950 rounded-lg border border-slate-800/80 text-center flex items-center justify-between text-xs font-mono text-slate-400">
            <span>Pressure Monitoring:</span>
            <span class="text-emerald-400 font-bold">NORMAL 🟢</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. 核心实力数据 -->
  <section class="max-w-7xl mx-auto px-6 -mt-12 relative z-20">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm text-center">
        <div class="text-3xl md:text-4xl font-extrabold text-emerald-600">15 GWh</div>
        <div class="text-xs md:text-sm text-slate-500 mt-1 font-medium">Planned Capacity</div>
      </div>
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm text-center">
        <div class="text-3xl md:text-4xl font-extrabold text-emerald-600">6000+ Cycles</div>
        <div class="text-xs md:text-sm text-slate-500 mt-1 font-medium">LFP Cycle Life</div>
      </div>
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm text-center">
        <div class="text-3xl md:text-4xl font-extrabold text-emerald-600">200+</div>
        <div class="text-xs md:text-sm text-slate-500 mt-1 font-medium">R&D Engineers</div>
      </div>
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm text-center">
        <div class="text-3xl md:text-4xl font-extrabold text-emerald-600">50+</div>
        <div class="text-xs md:text-sm text-slate-500 mt-1 font-medium">Delivery Countries</div>
      </div>
    </div>
  </section>

  <!-- 4. 推荐明星产品板块 -->
  <section class="max-w-7xl mx-auto px-6 py-20 bg-slate-100/50 rounded-3xl my-12 border border-slate-200/40">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12">
      <div>
        <span class="text-xs font-bold text-emerald-600 tracking-wider uppercase">Star Products</span>
        <h2 class="text-3xl font-extrabold text-slate-900 mt-2">Featured Products</h2>
        <p class="text-slate-500 mt-2 text-sm max-w-lg">
          Selected high energy density cells and highly compatible energy storage packs with automotive-grade quality assurance.
        </p>
      </div>
      <a href={resolveUrl('/en/products')} class="mt-4 md:mt-0 px-6 py-2.5 bg-slate-900 hover:bg-slate-800 text-white text-sm font-semibold rounded-lg transition-colors flex items-center gap-2">
        All Products ➔
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredProducts.length === 0 ? (
        <div class="col-span-2 text-center py-12 text-slate-400 text-sm">
          No English products found. Please add product files with "lang: en" in their Frontmatter to show here.
        </div>
      ) : (
        featuredProducts.map(product => (
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between">
            <div class="p-8">
              <div class="flex justify-between items-center mb-6">
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-50 px-3 py-1 rounded-full border border-emerald-100">
                  {product.data.chemistry}
                </span>
                <span class="text-xs text-slate-400 font-medium">{product.data.category}</span>
              </div>
              
              <div class="h-56 w-full bg-slate-50 rounded-xl flex items-center justify-center p-6 mb-6 border border-slate-100">
                <!-- 👈 修改：应用高宽、widths 和 sizes 属性，配合 Image 原生组件提供高阶渲染支持 -->
                <Image 
                  src={product.data.image} 
                  alt={product.data.title} 
                  width={350}
                  height={220}
                  widths={[200, 350]}
                  sizes="(max-width: 768px) 100vw, 350px"
                  class="max-h-full object-contain" 
                />
              </div>

              <h3 class="text-2xl font-bold text-slate-900 mb-3">{product.data.title}</h3>
              
              <!-- 指标摘要 -->
              <div class="grid grid-cols-2 gap-4 text-sm border-t border-slate-100 pt-4 mt-4">
                <div class="bg-slate-50 p-3 rounded-lg border border-slate-100">
                  <div class="text-xs text-slate-400">Capacity</div>
                  <div class="font-bold text-slate-800 mt-1">
                    {product.data.specs.find((s: any) => s.name.toLowerCase().includes('capacity') || s.name.includes('容量'))?.value || 'See Specs'}
                  </div>
                </div>
                <div class="bg-slate-50 p-3 rounded-lg border border-slate-100">
                  <div class="text-xs text-slate-400">Voltage</div>
                  <div class="font-bold text-slate-800 mt-1">
                    {product.data.specs.find((s: any) => s.name.toLowerCase().includes('voltage') || s.name.includes('电压'))?.value || 'See Specs'}
                  </div>
                </div>
              </div>
            </div>

            <div class="px-8 pb-8 bg-white">
              <a href={resolveUrl(`/en/products/${product.id}`)} class="block w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white text-center text-sm font-bold rounded-xl shadow-sm transition-colors">
                View Specifications ➔
              </a>
            </div>
          </div>
        ))
      )}
    </div>
  </section>

  <!-- 5. 智造实力与质量管理体系 -->
  <section class="bg-slate-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-6 space-y-6">
        <h2 class="text-3xl font-extrabold tracking-tight">Controlling Quality with Automotive-Grade Standards</h2>
        <p class="text-slate-300 leading-relaxed">
          Battery quality determines system safety. We implement an extremely rigorous quality control network and deploy full-process automated manufacturing execution systems (MES).
        </p>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Certified to automotive-grade <strong>IATF 16949</strong> management system</li>
          <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Fully automated cleanroom (Class 10k, extreme dew point control)</li>
          <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> 100% X-ray, charge/discharge, and ultrasonic non-destructive testing</li>
          <li class="flex items-center gap-2"><span class="text-emerald-400">✓</span> Products fully comply with global safety standards: UL, CE, CB, UN38.3, IEC</li>
        </ul>
      </div>
      <div class="lg:col-span-6 grid grid-cols-2 gap-4">
        <div class="bg-slate-800 p-6 rounded-xl border border-slate-700 text-center">
          <div class="text-2xl font-bold text-emerald-400">Class 10,000</div>
          <div class="text-xs text-slate-400 mt-1">Cleanroom Dust Control</div>
        </div>
        <div class="bg-slate-800 p-6 rounded-xl border border-slate-700 text-center">
          <div class="text-2xl font-bold text-emerald-400">98.5%</div>
          <div class="text-xs text-slate-400 mt-1">Production Automation Rate</div>
        </div>
        <div class="bg-slate-800 p-6 rounded-xl border border-slate-700 text-center">
          <div class="text-2xl font-bold text-emerald-400">100%</div>
          <div class="text-xs text-slate-400 mt-1">Full-Process Serialized Traceability</div>
        </div>
        <div class="bg-slate-800 p-6 rounded-xl border border-slate-700 text-center">
          <div class="text-2xl font-bold text-emerald-400">CNAS</div>
          <div class="text-xs text-slate-400 mt-1">National Joint Laboratory</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. 页脚 -->
  <footer class="bg-slate-950 text-slate-500 py-12 px-6 border-t border-slate-900">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div class="space-y-4">
        <div class="text-white font-bold text-lg flex items-center gap-2">🔋 JC New Energy</div>
        <p class="text-xs leading-relaxed">Committed to providing high-safety, green, and highly efficient battery technologies, serving global zero-carbon and energy transition strategies.</p>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm mb-4">Product Center</h4>
        <ul class="space-y-2 text-xs">
          <li><a href={resolveUrl('/en/products')} class="hover:text-white transition-colors">ESS Batteries</a></li>
          <li><a href={resolveUrl('/en/products')} class="hover:text-white transition-colors">E-Mobility series</a></li>
          <li><a href={resolveUrl('/en/products')} class="hover:text-white transition-colors">Industrial Packs</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm mb-4">Standards & Certs</h4>
        <ul class="space-y-2 text-xs">
          <li>IATF 16949 Auto Quality</li>
          <li>ISO 9001 / 14001</li>
          <li>UL1973 / IEC62619 / UN38.3</li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm mb-4">Global HQ</h4>
        <p class="text-xs leading-relaxed">No. 88, New Energy Road, National High-tech Industrial Zone, China<br />Tel: +86 (512) 8888-8888<br />Email: info@jc-batteryway.com</p>
      </div>
    </div>
    <div class="max-w-7xl mx-auto border-t border-slate-900 pt-8 flex flex-col md:flex-row justify-between items-center text-xs">
      <div>© {new Date().getFullYear()} JC New Energy Co., Ltd. All rights reserved.</div>
      <div class="flex gap-4 mt-4 md:mt-0">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">ICP Record No. xxxxxx</a>
      </div>
    </div>
  </footer>

</body>

<!-- 监控面板数据模拟波动脚本 -->
<script is:inline>
  const vEl = document.getElementById('live-voltage');
  const tEl = document.getElementById('live-temp');
  
  if (vEl && tEl) {
    setInterval(() => {
      const fakeVoltage = (3.280 + Math.random() * 0.008).toFixed(3);
      vEl.textContent = `${fakeVoltage} V`;
      
      const fakeTemp = (25.1 + Math.random() * 0.4).toFixed(1);
      tEl.textContent = `${fakeTemp} ℃`;
    }, 2000);
  }
</script>
</html>