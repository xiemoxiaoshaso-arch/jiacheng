---
import '../../styles/global.css';
import Header from '../../components/Header.astro'; // 👈 引入通用智能导航组件

// 👈 统一处理链接和公开静态资源路径的辅助函数（自动补全域名根路径前缀）
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Company Profile - JC New Energy</title>
</head>
<body class="bg-white text-slate-800 font-sans">

  <!-- 1. 引入通用智能导航栏 -->
  <Header />

  <!-- 2. 🌟 品牌定制·公司简介高清无界微光巨幕 Banner (电影级高对比：暗大图 + 发光白字，完美可读) -->
  <section class="relative w-full h-[320px] md:h-[460px] overflow-hidden flex items-center justify-center bg-slate-950 border-b border-slate-200/60">
    <img 
      src={resolveUrl('/images/about-banner.jpg')}
      alt="Leading Zero-Carbon Transformation" 
      class="absolute inset-0 w-full h-full object-cover opacity-90 hover:scale-[1.01] transition-transform duration-[12000ms] ease-out"
    />
    
    <div class="absolute inset-0 bg-slate-950/45 pointer-events-none"></div>
    
    <div class="absolute inset-0 bg-gradient-to-tr from-emerald-500/10 via-transparent to-cyan-500/10 pointer-events-none"></div>
    
    <div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-white/20 to-transparent pointer-events-none"></div>

    <div class="relative z-10 max-w-5xl mx-auto text-center px-4 md:px-8 space-y-4">
      <span class="inline-block px-3 py-1 bg-emerald-500/20 text-emerald-300 text-[10px] font-bold tracking-widest uppercase rounded-full border border-emerald-500/30">
        ABOUT US // COMPANY PROFILE
      </span>
      
      <h1 class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-black text-white tracking-tight leading-tight md:leading-snug break-words max-w-4xl mx-auto drop-shadow-[0_2px_15px_rgba(0,0,0,0.5)]">
        Leading Zero-Carbon Transformation, <br class="hidden md:inline" />Powering the World
      </h1>
      
      <p class="text-emerald-400 font-bold text-[9px] md:text-xs tracking-wider md:tracking-widest uppercase font-mono max-w-2xl mx-auto drop-shadow-[0_1px_5px_rgba(0,0,0,0.3)] leading-relaxed">
        LEADING THE ZERO-CARBON TRANSFORMATION WITH NEXT-GENERATION BATTERY TECHNOLOGY
      </p>
    </div>
  </section>

  <!-- 3. 企业简介正文过渡区 (纯白通栏区 - bg-white) -->
  <section class="w-full bg-white py-16 border-b border-slate-100">
    <div class="max-w-4xl mx-auto text-center px-6">
      <p class="text-slate-500 text-sm md:text-base leading-relaxed max-w-2xl mx-auto">
        JC New Energy Co., Ltd. is a national-level high-tech enterprise. Since our inception, we have been fully committed to the research, development, precision manufacturing, and global delivery of high-safety, high-energy-density Lithium Iron Phosphate (LFP) and ternary lithium cells, modules, and full battery packs.
      </p>
    </div>
  </section>

  <!-- 4. 企业实力数据看板 (冷灰色通栏 - bg-slate-100 + 升级版锐利边框卡片 border-slate-300) -->
  <section id="stats-section" class="w-full bg-slate-100 py-20 border-b border-slate-200 transform transition-all duration-1000 ease-out">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <!-- 卡片 1 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-300 shadow-sm text-center md:text-left hover:shadow-md transition-all">
          <div class="text-3xl font-extrabold text-emerald-600 font-mono">150,000 ㎡</div>
          <div class="text-xs font-bold text-slate-400 mt-2 uppercase tracking-wider">Manufacturing Base</div>
          <p class="text-xs text-slate-500 mt-2 leading-relaxed">Equipped with highly automated, Class 10,000 cleanroom-standard modern green production facilities.</p>
        </div>

        <!-- 卡片 2 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-300 shadow-sm text-center md:text-left hover:shadow-md transition-all">
          <div class="text-3xl font-extrabold text-emerald-600 font-mono">15 GWh</div>
          <div class="text-xs font-bold text-slate-400 mt-2 uppercase tracking-wider">Planned Capacity</div>
          <p class="text-xs text-slate-500 mt-2 leading-relaxed">Fully integrated with Industry 4.0 equipment and intelligent MES full-process traceability systems.</p>
        </div>

        <!-- 卡片 3 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-300 shadow-sm text-center md:text-left hover:shadow-md transition-all">
          <div class="text-3xl font-extrabold text-emerald-600 font-mono">200+</div>
          <div class="text-xs font-bold text-slate-400 mt-2 uppercase tracking-wider">R&D Engineers</div>
          <p class="text-xs text-slate-500 mt-2 leading-relaxed">Core technical team originates from top-tier research institutes, securing numerous independent technological breakthroughs.</p>
        </div>

        <!-- 卡片 4 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-300 shadow-sm text-center md:text-left hover:shadow-md transition-all">
          <div class="text-3xl font-extrabold text-emerald-600 font-mono">180+</div>
          <div class="text-xs font-bold text-slate-400 mt-2 uppercase tracking-wider">Patents Granted</div>
          <p class="text-xs text-slate-500 mt-2 leading-relaxed">Holding core intellectual property rights across material modification, pole piece coating, and intelligent BMS control.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 5. 核心：深黑色底盘 + 3D悬浮白色小卡片时间轴 (border-white/25 + bg-slate-50/95) -->
  <section id="timeline-section" class="w-full bg-slate-900 py-24 text-white border-b border-slate-950 relative overflow-hidden transform transition-all duration-1000 ease-out">
    <div class="absolute -top-12 -left-12 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-3xl mx-auto px-6 relative z-10">
      <div class="text-center mb-16">
        <span class="text-xs font-bold text-emerald-400 tracking-wider uppercase font-mono">Our Footsteps</span>
        <h2 class="text-3xl font-extrabold text-white mt-2">Development Timeline</h2>
        <p class="text-slate-400 mt-2 text-sm">Every step represents our ultimate pursuit of premium quality and advanced technology</p>
      </div>

      <!-- 垂直轨道 -->
      <div class="relative border-l-2 border-white/25 pl-8 ml-4 md:ml-auto">
        
        <!-- 里程碑 2026 -->
        <div class="relative mb-12 group">
          <span class="absolute -left-[41px] top-6 w-6 h-6 rounded-full bg-white border-4 border-emerald-500 flex items-center justify-center shadow-[0_0_10px_rgba(16,185,129,0.3)] group-hover:scale-110 transition-transform"></span>
          
          <div class="bg-slate-50/95 p-6 rounded-2xl border border-slate-200 hover:border-emerald-500/30 shadow-[0_15px_30px_rgba(0,0,0,0.22)] hover:shadow-[0_18px_35px_rgba(16,185,129,0.12)] transition-all">
            <div class="text-lg font-extrabold text-slate-900 font-mono">2026</div>
            <h3 class="text-sm font-bold text-emerald-600 mt-0.5">Global Expansion & Capacity Leap</h3>
            <p class="text-xs text-slate-500 mt-2 leading-relaxed">
              The Phase II 10 GWh smart energy storage cell production lines successfully commenced operation. Simultaneously established localized warehousing and technical support hubs in Europe and North America, exporting products to over 50 countries and regions globally.
            </p>
          </div>
        </div>

        <!-- 里程碑 2024 -->
        <div class="relative mb-12 group">
          <span class="absolute -left-[41px] top-6 w-6 h-6 rounded-full bg-white border-4 border-emerald-500 flex items-center justify-center shadow-[0_0_10px_rgba(16,185,129,0.3)] group-hover:scale-110 transition-transform"></span>
          
          <div class="bg-slate-50/95 p-6 rounded-2xl border border-slate-200 hover:border-emerald-500/30 shadow-[0_15px_30px_rgba(0,0,0,0.22)] hover:shadow-[0_18px_35px_rgba(16,185,129,0.12)] transition-all">
            <div class="text-lg font-extrabold text-slate-900 font-mono">2024</div>
            <h3 class="text-sm font-bold text-emerald-600 mt-0.5">Automotive-Grade Certification & Mass Delivery</h3>
            <p class="text-xs text-slate-500 mt-2 leading-relaxed">
              Successfully passed the stringent <strong>IATF 16949</strong> automotive quality management system certification. Energy storage battery packs and power cells achieved large-scale mass delivery to premium domestic and international tier-1 system integrators.
            </p>
          </div>
        </div>

        <!-- 里程碑 2022 -->
        <div class="relative mb-12 group">
          <span class="absolute -left-[41px] top-6 w-6 h-6 rounded-full bg-white border-4 border-emerald-500 flex items-center justify-center shadow-[0_0_10px_rgba(16,185,129,0.3)] group-hover:scale-110 transition-transform"></span>
          
          <div class="bg-slate-50/95 p-6 rounded-2xl border border-slate-200 hover:border-emerald-500/30 shadow-[0_15px_30px_rgba(0,0,0,0.22)] hover:shadow-[0_18px_35px_rgba(16,185,129,0.12)] transition-all">
            <div class="text-lg font-extrabold text-slate-900 font-mono">2022</div>
            <h3 class="text-sm font-bold text-emerald-600 mt-0.5">Phase I Production & Joint Lab Inauguration</h3>
            <p class="text-xs text-slate-500 mt-2 leading-relaxed">
              Company’s Phase I LFP 280Ah ESS cell production line officially rolled out. The national standard joint laboratory (CNAS) was completed, fully equipped with comprehensive charge-discharge systems and ultrasonic non-destructive testing capabilities.
            </p>
          </div>
        </div>

        <!-- 里程碑 2020 -->
        <div class="relative group">
          <span class="absolute -left-[41px] top-6 w-6 h-6 rounded-full bg-white border-4 border-emerald-500 flex items-center justify-center shadow-[0_0_10px_rgba(16,185,129,0.3)] group-hover:scale-110 transition-transform"></span>
          
          <div class="bg-slate-50/95 p-6 rounded-2xl border border-slate-200 hover:border-emerald-500/30 shadow-[0_15px_30px_rgba(0,0,0,0.22)] hover:shadow-[0_18px_35px_rgba(16,185,129,0.12)] transition-all">
            <div class="text-lg font-extrabold text-slate-900 font-mono">2020</div>
            <h3 class="text-sm font-bold text-emerald-600 mt-0.5">Tech Startup & Core Material Breakthroughs</h3>
            <p class="text-xs text-slate-500 mt-2 leading-relaxed">
              JC New Energy was officially established with its headquarters and R&D hub inaugurated. The core team overcame high-cycle LFP material modification technical challenges, laying a solid foundation for extreme safety and long-lifecycle performance.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 6. 全球化布局 (冷灰色通栏 - bg-slate-100 + 升级版高对比卡片 border-slate-300) -->
  <section id="network-section" class="w-full bg-slate-100 py-20 border-b border-slate-200 transform transition-all duration-1000 ease-out">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="text-xs font-bold text-emerald-600 tracking-wider uppercase font-mono">Global Supply Chain</span>
        <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mt-2">Global Service Network</h2>
        <p class="text-xs text-slate-400 mt-1">Leveraging advanced manufacturing to serve the global low-carbon energy transition</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- 亚太 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-300 shadow-sm hover:border-emerald-500/40 hover:shadow-md transition-all">
          <div class="text-lg font-bold text-slate-900">🇨🇳 China • HQ & R&D Center</div>
          <p class="text-[10px] text-slate-400 mt-1">Headquarters & Main Production</p>
          <p class="text-xs text-slate-500 mt-4 leading-relaxed">
            Located in the National High-tech Industrial Zone. It hosts the group’s fully automated smart manufacturing facilities, CNAS joint laboratories, BMS hardware/software engineering centers, and serves as our primary capacity orchestration and supply chain logistics hub.
          </p>
        </div>

        <!-- 欧洲 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-300 shadow-sm hover:border-emerald-500/40 hover:shadow-md transition-all">
          <div class="text-lg font-bold text-slate-900">🇩🇪 Germany • Europe Service Center</div>
          <p class="text-[10px] text-slate-400 mt-1">Europe Sales & Technical Support</p>
          <p class="text-xs text-slate-500 mt-4 leading-relaxed">
            Established in Frankfurt, Germany. It provides European regional clients—such as Commercial & Industrial (C&I) energy storage integrators and microgrid EPC firms—with localized inventory, rapid spare parts distribution, and highly responsive field engineering support.
          </p>
        </div>

        <!-- 北美 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-300 shadow-sm hover:border-emerald-500/40 hover:shadow-md transition-all">
          <div class="text-lg font-bold text-slate-900">🇺🇸 USA • North America Office</div>
          <p class="text-[10px] text-slate-400 mt-1">North America Business Development</p>
          <p class="text-xs text-slate-500 mt-4 leading-relaxed">
            Based in California, USA. The team deeply aligns with North American clean energy policies and regional compliance/certification frameworks (e.g., UL 9540A), focusing heavily on scaling commercial, industrial, and high-end residential ESS business lines.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. 页脚 -->
  <footer class="bg-slate-900 text-slate-400 py-16 px-6 border-t border-slate-950">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8 mb-8 text-left">
      <div class="space-y-4">
        <div class="text-white font-bold text-lg flex items-center gap-2">🔋 JC New Energy</div>
        <p class="text-xs leading-relaxed text-slate-400">Dedicated to driving the global zero-carbon economic transformation through safe, green, and highly efficient battery technologies.</p>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm mb-4">Products</h4>
        <ul class="space-y-2 text-xs text-slate-400">
          <li><a href={resolveUrl('/products')} class="hover:text-emerald-400 transition-colors">ESS Solutions</a></li>
          <li><a href={resolveUrl('/products')} class="hover:text-emerald-400 transition-colors">E-Mobility Series</a></li>
          <li><a href={resolveUrl('/products')} class="hover:text-emerald-400 transition-colors">Industrial Battery Packs</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm mb-4">Quality & Standards</h4>
        <ul class="space-y-2 text-xs text-slate-400">
          <li>IATF 16949 Automotive Quality</li>
          <li>ISO 9001 / ISO 14001 Standards</li>
          <li>UL1973 / IEC62619 / UN38.3 Certified</li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm mb-4">Global HQ</h4>
        <p class="text-xs leading-relaxed text-slate-400">No. 88, New Energy Road, National High-tech Industrial Zone, China<br />Tel: +86 (512) 8888-8888<br />Email: info@jc-batteryway.com</p>
      </div>
    </div>
    <div class="max-w-7xl mx-auto border-t border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-slate-500">
      <div>© {new Date().getFullYear()} JC New Energy Co., Ltd. All rights reserved.</div>
      <div class="flex gap-4 mt-4 md:mt-0">
        <a href="#" class="hover:text-emerald-400 transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-emerald-400 transition-colors">Terms of Service</a>
      </div>
    </div>
  </footer>

  <!-- ----------------- 🚀 高性能滚动渐入脚本 (Astro 标准托管，严防白屏) ----------------- -->
  <script>
    const elStats = document.getElementById('stats-section');
    const elTimeline = document.getElementById('timeline-section');
    const elNetwork = document.getElementById('network-section');

    // 只有在浏览器成功加载并执行了 JS 时，才赋予初始隐匿状态，实现优雅降级
    if (elStats) elStats.classList.add('opacity-0', 'translate-y-8');
    if (elTimeline) elTimeline.classList.add('opacity-0', 'translate-y-8');
    if (elNetwork) elNetwork.classList.add('opacity-0', 'translate-y-8');

    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target); // 触发后即时注销监听
        }
      });
    }, { threshold: 0.05 });

    if (elStats) revealObserver.observe(elStats);
    if (elTimeline) revealObserver.observe(elTimeline);
    if (elNetwork) revealObserver.observe(elNetwork);
  </script>

</body>
</html>