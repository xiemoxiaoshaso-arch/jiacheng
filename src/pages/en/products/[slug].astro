---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets'; 
import '../../../styles/global.css';
import Header from '../../../components/Header.astro'; 

export async function getStaticPaths() {
  const products = await getCollection('products');
  
  // 👈 Unified: Filter only English products based on Frontmatter lang === 'en'
  const enProducts = products.filter(product => product.data.lang === 'en');
  
  return enProducts.map(product => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { title, category, chemistry, image, datasheet, specs, images } = product.data;
const { Content } = await render(product);

// Fallback logic for product gallery images
const galleryImages = images && images.length > 0 ? images : [image];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};

// Specification translation mapping dictionary
const specNameMap: Record<string, string> = {
  '标称电压': 'Nominal Voltage',
  '额定电压': 'Rated Voltage',
  '标称容量': 'Nominal Capacity',
  '额定容量': 'Rated Capacity',
  '工作电压范围': 'Operating Voltage Range',
  '内阻': 'Internal Impedance',
  '最大连续充放电电流': 'Max. Continuous Charge/Discharge Current',
  '最大持续电流': 'Max. Continuous Current',
  '工作温度': 'Operating Temperature',
  '存储温度': 'Storage Temperature',
  '循环寿命': 'Cycle Life',
  '重量': 'Weight',
  '尺寸': 'Dimensions (W*D*H)'
};

const getCleanSpecName = (name: string) => {
  const trimmed = name.trim();
  return specNameMap[trimmed] || trimmed;
};
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - JC New Energy</title>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased">

  <!-- 1. Universal Header Navigation -->
  <Header />

  <!-- 2. Main Content Container -->
  <main class="max-w-7xl mx-auto px-4 py-12 space-y-8">
    
    <nav class="text-xs font-semibold text-slate-400 tracking-wider uppercase">
      <a href={resolveUrl('/en')} class="hover:text-emerald-600 transition-colors">Home</a> &gt; 
      <a href={resolveUrl('/en/products')} class="hover:text-emerald-600 transition-colors">Products</a> &gt; 
      <span class="text-slate-500">{category}</span> &gt; 
      <span class="text-slate-600 font-medium">{title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Left Column: Product Gallery & Datasheet Download -->
      <div class="lg:col-span-5 bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col items-center w-full">
        
        <!-- Main Product Gallery Box -->
        <div class="w-full aspect-square bg-slate-50 rounded-xl overflow-hidden flex items-center justify-center p-8 border border-slate-100 relative">
          {galleryImages.map((imgObj, index) => (
            <Image 
              src={imgObj} 
              alt={`${title} view ${index + 1}`} 
              width={600}
              height={600}
              widths={[300, 600, 900]}
              sizes="(max-width: 768px) 100vw, 500px"
              loading={index === 0 ? "eager" : "lazy"}
              class={`product-gallery-main w-full h-full object-contain absolute transition-all duration-300 ${index === 0 ? 'opacity-100 scale-100 pointer-events-auto' : 'opacity-0 scale-95 pointer-events-none'}`}
              data-gallery-index={index}
            />
          ))}
        </div>

        <!-- Thumbnail Gallery Carousel -->
        {galleryImages.length > 1 && (
          <div class="flex gap-2.5 mt-4 w-full overflow-x-auto pb-1 scrollbar-none justify-start">
            {galleryImages.map((imgObj, index) => (
              <button 
                class={`thumb-btn w-16 h-16 rounded-xl border overflow-hidden flex items-center justify-center p-1 bg-slate-50 shrink-0 cursor-pointer transition-all ${index === 0 ? 'border-emerald-600 ring-4 ring-emerald-500/10' : 'border-slate-200 hover:border-slate-300'}`}
                data-target-index={index}
              >
                <Image src={imgObj} alt="Thumbnail view" width={60} height={60} class="max-h-full object-contain pointer-events-none" />
              </button>
            ))}
          </div>
        )}

        <button id="download-trigger-btn" class="mt-6 w-full py-3.5 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl shadow-md shadow-emerald-600/10 transition-all cursor-pointer text-sm uppercase tracking-widest transition-colors">
          📥 Download Technical Datasheet (PDF)
        </button>

        <!-- Compliance & Certifications Panel -->
        <div class="w-full mt-6 border-t border-slate-100 pt-6">
          <h4 class="text-[11px] font-bold text-slate-400 tracking-widest uppercase mb-4 flex items-center gap-1.5">
            <span class="w-1 h-2.5 bg-emerald-600 rounded-sm"></span>
            Global Compliance & Certifications
          </h4>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-slate-50/50 p-2.5 rounded-xl border border-slate-200 hover:border-emerald-500/20 transition-all flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-left">
                <div class="text-[10px] font-extrabold text-slate-800 leading-tight">UL 1973</div>
                <div class="text-[8px] font-bold text-slate-400 font-mono">North America</div>
              </div>
            </div>
            <div class="bg-slate-50/50 p-2.5 rounded-xl border border-slate-200 hover:border-emerald-500/20 transition-all flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-left">
                <div class="text-[10px] font-extrabold text-slate-800 leading-tight">IEC 62619</div>
                <div class="text-[8px] font-bold text-slate-400 font-mono">Europe Industrial</div>
              </div>
            </div>
            <div class="bg-slate-50/50 p-2.5 rounded-xl border border-slate-200 hover:border-emerald-500/20 transition-all flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-left">
                <div class="text-[10px] font-extrabold text-slate-800 leading-tight">UN 38.3</div>
                <div class="text-[8px] font-bold text-slate-400 font-mono">Transportation</div>
              </div>
            </div>
            <div class="bg-slate-50/50 p-2.5 rounded-xl border border-slate-200 hover:border-emerald-500/20 transition-all flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="text-left">
                <div class="text-[10px] font-extrabold text-slate-800 leading-tight">CE / CB</div>
                <div class="text-[8px] font-bold text-slate-400 font-mono">EU Safety</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Product Specs & Customization Prompt -->
      <div class="lg:col-span-7 bg-white p-8 rounded-2xl shadow-sm border border-slate-200 flex flex-col justify-between w-full h-full space-y-6">
        <div>
          <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs font-bold rounded-full border border-emerald-100 uppercase tracking-wider">{chemistry} | {category}</span>
          <h1 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight mt-3">{title}</h1>
          <p class="text-slate-500 mt-2 text-xs md:text-sm leading-relaxed font-medium">
            Engineered precisely for high-standard energy storage and electric mobility applications. Features lifecycle safety monitoring, excellent thermal stability, and robust rate-discharge performance. Supports multi-dimensional custom specifications.
          </p>
        </div>

        <!-- Technical Specification Table -->
        <div>
          <h2 class="text-xs font-bold text-slate-400 mb-3 flex items-center gap-1.5 uppercase tracking-widest font-mono">
            📊 Technical Specifications
          </h2>
          <div class="overflow-hidden border border-slate-200 rounded-xl shadow-sm">
            <table class="min-w-full divide-y divide-slate-150 bg-white">
              <tbody class="divide-y divide-slate-100">
                {specs.map((spec: any, index: number) => (
                  <tr class={index % 2 === 0 ? 'bg-slate-50/40' : 'bg-white'}>
                    <td class="px-5 py-4 text-xs font-bold text-slate-500 w-1/2 border-r border-slate-100 uppercase tracking-wide">{getCleanSpecName(spec.name)}</td>
                    <td class="px-5 py-4 text-xs font-black text-slate-900 font-mono">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="p-5 bg-slate-50/60 rounded-xl border border-slate-150 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <div class="space-y-0.5">
            <h3 class="font-extrabold text-slate-900 text-xs md:text-sm">Need custom solutions or volume pricing?</h3>
            <p class="text-[11px] text-slate-400 font-medium leading-relaxed">Our application engineers are ready to build complete battery pack or system solutions tailored to your project.</p>
          </div>
          <!-- 👈 Unified: Adjusted contact path to /en/contact -->
          <a href={resolveUrl('/en/contact')} class="px-4 py-2.5 bg-slate-900 hover:bg-slate-800 text-white font-bold text-xs rounded-xl transition-colors shadow-sm shrink-0 uppercase tracking-widest font-mono">
            Contact Engineers ➔
          </a>
        </div>
      </div>

    </div>

    <!-- Description Content with Prose Typography overrides -->
    <section class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 prose prose-slate max-w-none prose-p:text-slate-600 prose-p:text-sm md:prose-p:text-base prose-p:leading-relaxed prose-headings:font-bold prose-headings:text-slate-900">
      <h2 class="text-sm font-bold text-slate-400 border-b border-slate-150 pb-3 uppercase tracking-widest font-mono mb-4">Applications & Technical Details</h2>
      <div class="mt-4 text-sm leading-relaxed font-medium">
        <Content />
      </div>
    </section>

  </main>

  <!-- Lead Modal Container -->
  <div id="pdf-lead-modal" class="fixed inset-0 bg-slate-950/60 backdrop-blur-sm flex items-center justify-center z-[100] opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl border border-slate-200 relative transform translate-y-4 transition-transform duration-300" id="modal-box">
      <button id="close-modal-btn" class="absolute top-4 right-4 w-7 h-7 bg-slate-50 hover:bg-slate-100 rounded-full flex items-center justify-center text-slate-400 hover:text-slate-600 text-xs cursor-pointer transition-colors">✕</button>
      
      <div class="text-center mb-6">
        <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center text-xl mx-auto mb-3">📄</div>
        <h3 class="text-lg font-black text-slate-900 tracking-tight">Request Product Datasheet</h3>
        <p class="text-xs text-slate-400 mt-1.5 font-medium leading-relaxed">Please provide your work details to unlock immediate download. A backup copy will also be sent to your inbox.</p>
      </div>

      <form id="lead-form" class="space-y-4">
        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Work Email*</label>
          <input type="email" id="lead-email" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none focus:border-emerald-500 bg-slate-50" placeholder="partner@company.com" />
        </div>
        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Country / Region*</label>
          <input type="text" id="lead-country" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none focus:border-emerald-500 bg-slate-50" placeholder="e.g., Germany, USA, Australia" />
        </div>
        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Application Scenario*</label>
          <select id="lead-app" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-xs font-bold focus:outline-none focus:border-emerald-500 bg-slate-50 text-slate-700">
            <option value="">Select an option...</option>
            <option value="ESS">Energy Storage System (ESS)</option>
            <option value="EV">Electric Mobility (EV / E-Mobility)</option>
            <option value="Industrial">Industrial & Consumer Batteries</option>
            <option value="Other">Other Scenarios</option>
          </select>
        </div>

        <button type="submit" class="w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl text-xs tracking-widest shadow-md shadow-emerald-600/10 cursor-pointer uppercase transition-colors">
          Verify & Download ➔
        </button>
      </form>
    </div>
  </div>

  <!-- Interactive JavaScript layer -->
  <script is:inline define:vars={{ datasheet }}>
    const openBtn = document.getElementById('download-trigger-btn');
    const closeBtn = document.getElementById('close-modal-btn');
    const modal = document.getElementById('pdf-lead-modal');
    const modalBox = document.getElementById('modal-box');
    const form = document.getElementById('lead-form');

    // Gallery view toggle controls
    const mainImages = document.querySelectorAll('.product-gallery-main');
    const thumbBtns = document.querySelectorAll('.thumb-btn');

    thumbBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const targetBtn = e.currentTarget;
        const targetIndex = targetBtn.getAttribute('data-target-index');
        
        mainImages.forEach(img => {
          const imgIndex = img.getAttribute('data-gallery-index');
          if (imgIndex === targetIndex) {
            img.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
            img.classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
          } else {
            img.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
            img.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
          }
        });

        thumbBtns.forEach(b => {
          b.classList.remove('border-emerald-600', 'ring-4', 'ring-emerald-500/10');
          b.classList.add('border-slate-200');
        });
        targetBtn.classList.remove('border-slate-200');
        targetBtn.classList.add('border-emerald-600', 'ring-4', 'ring-emerald-500/10');
      });
    });

    // Modal and submission handler
    openBtn?.addEventListener('click', () => {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modalBox.classList.remove('translate-y-4');
    });

    function closeModal() {
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalBox.classList.add('translate-y-4');
    }
    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = document.getElementById('lead-email').value;
      const country = document.getElementById('lead-country').value;
      const app = document.getElementById('lead-app').value;

      console.log('🎉 Verified Corporate Lead Captured:', { email, country, app, timestamp: new Date() });

      const downloadLink = document.createElement('a');
      downloadLink.href = datasheet;
      downloadLink.download = datasheet.split('/').pop() || 'Datasheet.pdf';
      document.body.appendChild(downloadLink);
      downloadLink.click();
      document.body.removeChild(downloadLink);

      closeModal();
      alert('Your download has started! A technical sales manager will review your submission and reach out if any matching system blueprints are available for your scenario.');
    });
  </script>

</body>
</html>