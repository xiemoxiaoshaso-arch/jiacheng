---
import { getCollection } from 'astro:content'; 
import { Image } from 'astro:assets'; // Import Astro assets optimizer
import '../../styles/global.css';
import Header from '../../components/Header.astro'; 

// 1. 👈 Unified: Fetch all jobs and filter based on Frontmatter's lang === 'en'
const rawJobs = await getCollection('careers');
const englishJobs = rawJobs.filter(job => job.data.lang === 'en');

// 2. Sort jobs by sortOrder weight in ascending order (default to 99 if undefined)
const jobsList = englishJobs.sort((a, b) => {
  const orderA = a.data.sortOrder !== undefined ? a.data.sortOrder : 99;
  const orderB = b.data.sortOrder !== undefined ? b.data.sortOrder : 99;
  return orderA - orderB;
});

// 3. Unified helper function to handle base path prefixes (for subdirectory deployment)
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};

// Import banner from assets folder for automatic build-time optimization
import careersBanner from '../../assets/images/careers-banner.jpg'; 
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Careers & Opportunities - JC New Energy</title>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased">

  <!-- 1. Universal Header Navigation -->
  <Header />

  <!-- 2. Careers Banner Section -->
  <section class="relative w-full h-[300px] md:h-[400px] overflow-hidden flex items-center justify-center bg-slate-950 border-b border-slate-200/60">
    <Image 
      src={careersBanner}
      alt="Careers at JC New Energy" 
      widths={[600, 1200, 1800]}
      sizes="100vw"
      loading="eager"
      class="absolute inset-0 w-full h-full object-cover opacity-95 hover:scale-[1.02] transition-transform duration-[10000ms] ease-out"
    />
    <div class="absolute inset-0 bg-slate-950/35 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-green-500/10 via-transparent to-blue-500/10 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 right-0 h-10 bg-gradient-to-t from-white/30 to-transparent pointer-events-none"></div>

    <div class="relative z-10 max-w-5xl mx-auto text-center px-6 space-y-4">
      <span class="inline-block px-3 py-1 bg-green-500/20 text-green-300 text-[10px] font-bold tracking-widest uppercase rounded-full border border-green-500/30 animate-pulse">
        CAREERS WITH US // JOIN THE TEAM
      </span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-white tracking-tight leading-tight">
        <span class="inline-block">Powering Career Growth,</span> <span class="inline-block">Driving Zero-Carbon Future</span>
      </h1>
      <p class="text-green-400 font-extrabold text-[10px] md:text-xs tracking-wider uppercase font-mono drop-shadow-[0_1px_5px_rgba(0,0,0,0.3)]">
        JOIN JIACHENG, DEFINE THE FUTURE OF GREEN ENERGY WITH US
      </p>
    </div>
  </section>

  <!-- 3. Corporate Benefits & Culture (Standard Industrial Style) -->
  <section class="w-full bg-white py-16 border-b border-slate-100">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="p-5 bg-slate-50 rounded-2xl border border-slate-200/60 space-y-2">
          <div class="text-xl">🚀</div>
          <h4 class="font-bold text-slate-900 text-sm">Global Stage</h4>
          <p class="text-xs text-slate-400 leading-relaxed">Engage directly in top-tier global ESS & Lithium battery projects, collaborating with premium international industry experts.</p>
        </div>
        <div class="p-5 bg-slate-50 rounded-2xl border border-slate-200/60 space-y-2">
          <div class="text-xl">💰</div>
          <h4 class="font-bold text-slate-900 text-sm">Incentive System</h4>
          <p class="text-xs text-slate-400 leading-relaxed">Competitive base salaries paired with performance bonuses, alongside special incentives for core engineering breakthroughs.</p>
        </div>
        <div class="p-5 bg-slate-50 rounded-2xl border border-slate-200/60 space-y-2">
          <div class="text-xl">🛡️</div>
          <h4 class="font-bold text-slate-900 text-sm">Comprehensive Health</h4>
          <p class="text-xs text-slate-400 leading-relaxed">Premium corporate commercial insurance upgrades, mandatory annual physical examinations, and family healthcare care initiatives.</p>
        </div>
        <div class="p-5 bg-slate-50 rounded-2xl border border-slate-200/60 space-y-2">
          <div class="text-xl">🌱</div>
          <h4 class="font-bold text-slate-900 text-sm">Dual Career Tracks</h4>
          <p class="text-xs text-slate-400 leading-relaxed">Custom management and technical promotion channels backed by structured enterprise training to continuously empower your path.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Job Vacancies Grid -->
  <section id="positions-section" class="w-full bg-slate-100 pt-12 pb-16 border-b border-slate-200 transform transition-all duration-1000 ease-out">
    <div class="max-w-4xl mx-auto px-6 space-y-8">
      <div class="text-center">
        <span class="text-xs font-bold text-green-600 tracking-wider uppercase font-mono">Open Positions</span>
        <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mt-2">Current Job Vacancies</h2>
        <p class="text-xs text-slate-400 mt-1">Accelerate your career by joining JC New Energy's core talent pool.</p>
      </div>

      <!-- Job Position Cards Stacked List -->
      <div class="space-y-6">
        {jobsList.length === 0 ? (
          <div class="text-center py-12 text-slate-400 text-sm bg-white rounded-2xl border border-slate-300">
            No English job positions found. Please add career markdown files with "lang: en" in their Frontmatter.
          </div>
        ) : (
          jobsList.map(job => (
            <div class="bg-white rounded-2xl border border-slate-300 p-6 md:p-8 shadow-sm hover:shadow-md transition-shadow space-y-6">
              
              <!-- Card Header with Job Metadata -->
              <div class="border-b border-slate-100 pb-5">
                <div class="flex flex-wrap items-center gap-2.5">
                  <h3 class="text-lg md:text-xl font-black text-slate-900 leading-snug">{job.data.title}</h3>
                  <span class="px-2 py-0.5 bg-green-50 text-green-700 text-[10px] font-bold rounded border border-green-200 shrink-0">
                    {job.data.type}
                  </span>
                </div>
                
                <div class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-slate-400 font-medium mt-3">
                  <span class="flex items-center gap-1">
                    💼 <strong class="text-slate-600">{job.data.department}</strong>
                  </span>
                  <span class="text-slate-200 hidden sm:inline">|</span>
                  <span class="flex items-center gap-1">
                    📍 {job.data.location}
                  </span>
                  <span class="text-slate-200 hidden sm:inline">|</span>
                  <span class="flex items-center gap-1">
                    🕒 {job.data.experience}
                  </span>
                </div>
              </div>

              <!-- Responsibilities & Requirements -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-xs md:text-sm leading-relaxed">
                <div class="space-y-2">
                  <h4 class="font-extrabold text-slate-900 flex items-center gap-1.5">
                    <span class="w-1.5 h-3 bg-green-600 rounded-sm"></span> Key Responsibilities
                  </h4>
                  <ul class="list-disc pl-4 text-slate-500 space-y-1">
                    {job.data.responsibilities.map((resp: string) => <li>{resp}</li>)}
                  </ul>
                </div>
                <div class="space-y-2">
                  <h4 class="font-extrabold text-slate-900 flex items-center gap-1.5">
                    <span class="w-1.5 h-3 bg-green-600 rounded-sm"></span> Qualifications & Requirements
                  </h4>
                  <ul class="list-disc pl-4 text-slate-500 space-y-1">
                    {job.data.requirements.map((req: string) => <li>{req}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  </section>

  <!-- 5. Direct Resume Submission -->
  <section id="apply-section" class="w-full bg-white py-20 transform transition-all duration-1000 ease-out">
    <div class="max-w-4xl mx-auto px-6 text-center space-y-6">
      <div class="w-14 h-14 bg-green-50 text-green-600 rounded-full flex items-center justify-center text-2xl mx-auto shadow-sm">✉️</div>
      <h2 class="text-3xl font-extrabold text-slate-900">Direct Application</h2>
      <p class="text-slate-500 text-xs md:text-sm max-w-xl mx-auto leading-relaxed">
        If none of the open roles above perfectly match your expertise, yet you believe your technical proficiency or global expansion capabilities can bring exceptional value to JC New Energy, please email your CV and cover letter directly to our HR team:
      </p>
      
      <div class="inline-block bg-slate-50 border border-slate-200 px-8 py-4 rounded-2xl">
        <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Recruitment Email</div>
        <a href="mailto:hr@jc-batteryway.com" class="text-xl md:text-2xl font-black text-green-600 hover:text-green-700 hover:underline mt-1 block tracking-wide font-mono">
          hr@jc-batteryway.com
        </a>
      </div>
      <p class="text-[11px] text-slate-400">Subject Format Recommendation: [Application] Name - Position Title - Desired Location</p>
    </div>
  </section>

  <!-- 6. Footer -->
  <footer class="bg-slate-900 text-slate-400 py-16 px-6 border-t border-slate-950 mt-20">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <div>© {new Date().getFullYear()} JC New Energy Co., Ltd. All rights reserved.</div>
      <div class="flex gap-6">
        <a href={resolveUrl('/')} class="hover:text-green-600">Home</a>
        <a href={resolveUrl('/products')} class="hover:text-green-600">Products</a>
        <a href={resolveUrl('/contact')} class="hover:text-green-600">Contact Us</a>
      </div>
    </div>
  </footer>

  <!-- Scroll Reveal Animation Script -->
  <script>
    const elPositions = document.getElementById('positions-section');
    const elApply = document.getElementById('apply-section');

    if (elPositions) elPositions.classList.add('opacity-0', 'translate-y-8');
    if (elApply) elApply.classList.add('opacity-0', 'translate-y-8');

    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    if (elPositions) revealObserver.observe(elPositions);
    if (elApply) revealObserver.observe(elApply);
  </script>

</body>
</html>