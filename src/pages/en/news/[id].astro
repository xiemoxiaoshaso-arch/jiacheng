---
import { getCollection, render } from 'astro:content'; 
import { Image } from 'astro:assets'; // 👈 Import Astro assets optimizer
import '../../../styles/global.css';
import Header from '../../../components/Header.astro';

export async function getStaticPaths() {
  const newsList = await getCollection('news');
  
  // 👈 Unified: Filter only English news based on Frontmatter lang === 'en'
  const englishNews = newsList.filter(news => news.data.lang === 'en');
  
  return englishNews.map(news => ({
    params: { id: news.id },
    props: { news }
  }));
}

const { news } = Astro.props;
const { title, category, categoryName, date, views, image, description } = news.data;
const { Content } = await render(news); 

// Unified helper function to handle base path prefixes (for subdirectory deployment)
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};

// Localization dictionary for category display names
const categoryTranslation: Record<string, string> = {
  'corporate': 'Corporate News',
  'industry': 'Industry Insights'
};
const displayCategory = categoryTranslation[category] || categoryName;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - JC New Energy</title>
  {description && <meta name="description" content={description} />}
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased">

  <!-- 1. Universal Header Navigation -->
  <Header langAlt={resolveUrl(`/news/${news.id.replace('-en', '')}`)} />

  <!-- 2. Main Content Container -->
  <main class="max-w-4xl mx-auto px-4 py-12">
    
    <!-- 👈 Unified: Adjusted return path to /en/news -->
    <a href={resolveUrl('/en/news')} class="inline-flex items-center gap-1.5 text-xs font-bold text-slate-500 hover:text-green-600 transition-colors mb-6 group uppercase tracking-wider">
      ⬅ Back to News Center
    </a>

    <article class="bg-white rounded-3xl border border-slate-200 p-8 md:p-12 shadow-sm space-y-8">
      
      <div class="space-y-4 border-b border-slate-100 pb-6">
        <span class={`inline-block px-2.5 py-1 text-[10px] font-extrabold rounded-full border uppercase tracking-wider ${
          category === 'corporate' 
            ? 'bg-green-50 text-green-700 border-green-200/60' 
            : 'bg-cyan-50 text-cyan-700 border-cyan-200/60'
        }`}>
          {displayCategory}
        </span>
        <h1 class="text-2xl md:text-3xl font-black text-slate-900 leading-snug">
          {title}
        </h1>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-slate-400 font-mono">
          <span>📅 Date: {date}</span>
          <span>✍️ Author: JC Editorial Dept.</span>
          <span>👁️ Views: {views}</span>
        </div>
      </div>

      <div class="w-full aspect-video bg-slate-50 rounded-2xl overflow-hidden border border-slate-100 relative">
        <!-- 👈 Improved: Native Image configuration with specific dimensions and responsive width sets to protected against CLS -->
        <Image 
          src={image} 
          alt={title} 
          width={800}
          height={450}
          widths={[400, 800, 1200]}
          sizes="(max-width: 800px) 100vw, 800px"
          loading="eager"
          class="w-full h-full object-cover" 
        />
      </div>

      <!-- Optimized Typography for English prose layout -->
      <div class="prose prose-slate max-w-none prose-p:text-slate-600 prose-p:text-sm md:prose-p:text-base prose-p:leading-relaxed prose-headings:font-bold prose-headings:text-slate-900">
        <Content />
      </div>

      <div class="mt-12 p-6 bg-slate-50 rounded-2xl border border-slate-150/60 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div class="space-y-0.5">
          <h4 class="font-bold text-slate-900 text-sm">Follow JC New Energy for the Latest Innovations</h4>
          <p class="text-xs text-slate-400">Stay updated with cutting-edge lithium cell tech, custom battery packs, and global commercial ESS blueprints.</p>
        </div>
        <!-- 👈 Unified: Adjusted redirect path to /en/products -->
        <a href={resolveUrl('/en/products')} class="px-5 py-2.5 bg-slate-900 hover:bg-slate-800 text-white font-bold text-xs rounded-xl transition-all shadow-sm shrink-0 whitespace-nowrap uppercase tracking-wider">
          Explore Products ➔
        </a>
      </div>

    </article>

    <div class="text-center mt-12">
      <!-- 👈 Unified: Adjusted return path to /en/news -->
      <a href={resolveUrl('/en/news')} class="inline-flex px-6 py-3 bg-white border border-slate-200 hover:border-green-600 hover:text-green-600 text-slate-600 text-xs font-bold rounded-xl transition-colors shadow-sm uppercase tracking-wider">
        Back to News Center
      </a>
    </div>

  </main>

  <!-- 3. English Footer -->
  <footer class="bg-slate-900 text-slate-400 py-12 px-6 border-t border-slate-950 mt-20">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <div>© {new Date().getFullYear()} JC New Energy Co., Ltd. All rights reserved.</div>
      <div class="flex gap-6 uppercase tracking-wider font-semibold">
        <!-- 👈 Unified: Adjusted paths to English directory -->
        <a href={resolveUrl('/en')} class="hover:text-green-600">Home</a>
        <a href={resolveUrl('/en/products')} class="hover:text-green-600">Products</a>
        <a href={resolveUrl('/en/contact')} class="hover:text-green-600">Inquiry</a>
      </div>
    </div>
  </footer>

</body>
</html>